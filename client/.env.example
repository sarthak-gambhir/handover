# Dev server port (default 5173)
CLIENT_PORT=5173

# Dev server bind host (default localhost). Use 0.0.0.0 to expose on your LAN.
CLIENT_HOST=localhost

# Where the dev server proxies /api (REST + WebSocket).
# Defaults to http://localhost:${SERVER_PORT or 3000}.
# SERVER_PORT=3000
# API_TARGET=http://localhost:3000
