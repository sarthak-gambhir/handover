# Server port
PORT=3000

# Bind address. Default 0.0.0.0 (all interfaces). Use 127.0.0.1 to restrict to
# localhost only, or a specific NIC address to bind a single interface.
HOST=0.0.0.0

# Node environment: development | production
NODE_ENV=development

# Allowed client origin for CORS (dev). In prod the client is served same-origin.
CLIENT_ORIGIN=http://localhost:5173

# Per-file upload cap for the shared bucket, in bytes (default 100 MB)
MAX_FILE_BYTES=104857600

# Per-session in-memory bucket cap, in bytes (default 500 MB)
MAX_SESSION_BYTES=524288000

# Global in-memory storage cap for the shared bucket, in bytes (default 512 MB)
MAX_TOTAL_BYTES=536870912

# Optional TURN server for WebRTC NAT traversal. If unset, STUN-only.
# TURN_URL=turn:turn.example.com:3478
# TURN_USERNAME=user
# TURN_CREDENTIAL=pass
